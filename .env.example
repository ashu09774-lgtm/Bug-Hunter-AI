# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000/api
NODE_ENV=development

# Backend
API_PORT=4000
API_CORS_ORIGIN=http://localhost:3000
API_JSON_LIMIT=2mb
API_RATE_LIMIT_PER_MINUTE=120
AUTH_RATE_LIMIT_PER_MINUTE=10

# Database
# Supabase direct DB URLs are IPv6-only. Use the Session Pooler URL if your network cannot reach IPv6.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ai_bug_detection?schema=public

# Auth
JWT_SECRET=replace-with-a-long-random-secret
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# AI
GEMINI_API_KEY=
AI_SERVICE_URL=http://localhost:8000

# Storage
UPLOAD_DIR=uploads
REPOSITORY_CLONE_DIR=clones
GOOGLE_DRIVE_CLIENT_EMAIL=
GOOGLE_DRIVE_PRIVATE_KEY=
GOOGLE_DRIVE_FOLDER_ID=
GOOGLE_DRIVE_ARCHIVE_RETENTION_DAYS=7

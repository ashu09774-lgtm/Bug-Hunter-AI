# Frontend
NEXT_PUBLIC_APP_URL=https://your-vercel-app.vercel.app
NEXT_PUBLIC_API_URL=https://your-railway-api.up.railway.app/api
NODE_ENV=production

# Backend
API_PORT=4000
API_CORS_ORIGIN=https://your-vercel-app.vercel.app
API_JSON_LIMIT=2mb
API_RATE_LIMIT_PER_MINUTE=120
AUTH_RATE_LIMIT_PER_MINUTE=10

# Database
# Supabase direct DB URLs are IPv6-only. Use the Session Pooler URL if your host cannot reach IPv6.
DATABASE_URL=postgresql://user:password@host:5432/ai_bug_detection?schema=public

# Auth
JWT_SECRET=replace-with-at-least-32-random-characters
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# AI
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
AI_SERVICE_URL=https://your-ai-service.up.railway.app

# Storage
UPLOAD_DIR=uploads
REPOSITORY_CLONE_DIR=clones
GOOGLE_DRIVE_CLIENT_EMAIL=
GOOGLE_DRIVE_PRIVATE_KEY=
GOOGLE_DRIVE_FOLDER_ID=
GOOGLE_DRIVE_ARCHIVE_RETENTION_DAYS=7

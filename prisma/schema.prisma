generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ScanStatus {
  QUEUED
  RUNNING
  COMPLETED
  FAILED
  CANCELED
}

enum BugSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum BugStatus {
  OPEN
  FIXED
  IGNORED
  FALSE_POSITIVE
}

model User {
  id                      String                 @id @default(cuid())
  email                   String                 @unique
  username                String?
  bio                     String?
  passwordHash            String?
  avatarUrl               String?
  theme                   String                 @default("system")
  notificationPreferences Json?
  emailVerifiedAt         DateTime?
  resetPasswordTokenHash  String?
  resetPasswordExpiresAt  DateTime?
  emailVerifyTokenHash    String?
  emailVerifyExpiresAt    DateTime?
  createdAt               DateTime               @default(now())
  updatedAt               DateTime               @updatedAt
  repositories            Repository[]
  scans                   ScanHistory[]
  sessions                Session[]
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Repository {
  id            String        @id @default(cuid())
  userId        String
  name          String
  url           String
  provider      String        @default("github")
  defaultBranch String?
  language      String?
  isPrivate     Boolean       @default(false)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  scans         ScanHistory[]

  @@index([userId])
}

model ScanHistory {
  id           String       @id @default(cuid())
  userId       String
  repositoryId String?
  status       ScanStatus   @default(QUEUED)
  startedAt    DateTime?
  completedAt  DateTime?
  summary      Json?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  repository   Repository?  @relation(fields: [repositoryId], references: [id], onDelete: SetNull)
  bugReports   BugReport[]

  @@index([userId])
  @@index([repositoryId])
}

model BugReport {
  id            String         @id @default(cuid())
  scanHistoryId String
  title         String
  description   String
  filePath      String
  lineNumber    Int?
  language      String?
  category      String?
  severity      BugSeverity    @default(MEDIUM)
  status        BugStatus      @default(OPEN)
  analyzer      String
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  scanHistory   ScanHistory    @relation(fields: [scanHistoryId], references: [id], onDelete: Cascade)
  aiSuggestions AiSuggestion[]

  @@index([scanHistoryId])
  @@index([severity])
}

model AiSuggestion {
  id            String    @id @default(cuid())
  bugReportId   String
  explanation   String
  suggestedFix  String?
  confidence    Float?
  model         String?
  createdAt     DateTime  @default(now())
  bugReport     BugReport @relation(fields: [bugReportId], references: [id], onDelete: Cascade)

  @@index([bugReportId])
}
